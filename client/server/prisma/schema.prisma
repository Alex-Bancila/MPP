generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  Active
  Sold
}

enum UserRoleName {
  admin
  user
}

model User {
  id           String         @id
  username     String
  email        String         @unique
  passwordHash String
  avatarUrl    String
  createdAt    DateTime
  roleId       String
  banned       Boolean        @default(false)
  bannedReason String?
  bannedAt     DateTime?

  listings      Listing[]
  reviews       Review[]
  favourites    Favourite[]
  conversations Conversation[] @relation("ConversationParticipantA")
  conversationsAsB Conversation[] @relation("ConversationParticipantB")
  messages      Message[]
  actionLogs    ActionLog[]
  suspiciousEntries SuspiciousUser[]
  adminRequests AdminAccessRequest[]
  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([roleId])
  @@index([banned])
}

model AdminAccessRequest {
  id           String   @id
  userId       String
  status       String   @default("pending")
  note         String?
  createdAt    DateTime
  resolvedAt   DateTime?
  resolvedById String?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Listing {
  id          String         @id
  sellerId    String
  title       String
  description String
  price       Int
  category    String
  photos      Json
  datePosted  DateTime
  status      ListingStatus

  seller       User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  reviews      Review[]
  favourites   Favourite[]
  conversations Conversation[]

  @@index([category])
  @@index([status])
  @@index([datePosted])
  @@index([price])
  @@index([sellerId])
}

model Review {
  id         String   @id
  listingId  String
  userId     String
  rating     Int
  title      String
  body       String
  createdAt  DateTime
  updatedAt  DateTime

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([userId])
}

model Favourite {
  userId    String
  listingId String
  createdAt DateTime

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@index([listingId])
}

model Conversation {
  id            String   @id
  listingId     String
  participantAId String
  participantBId String
  createdAt      DateTime

  listing      Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  participantA User    @relation("ConversationParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB User    @relation("ConversationParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([listingId])
  @@index([participantAId])
  @@index([participantBId])
}

model Message {
  id             String   @id
  conversationId  String
  senderId        String
  body            String
  createdAt       DateTime
  readAt          DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Role {
  id          String           @id
  name        UserRoleName      @unique
  description String?

  users       User[]
  permissions RolePermission[]
  actionLogs  ActionLog[]
  suspiciousEntries SuspiciousUser[]
}

model Permission {
  id          String           @id
  name        String           @unique
  description String?

  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId  String

  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model ActionLog {
  id          String   @id
  userId      String
  roleId      String
  action      String
  details     String
  createdAt   DateTime

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleId])
  @@index([createdAt])
}

model SuspiciousUser {
  id          String   @id
  userId      String
  roleId      String
  reason      String
  score       Int
  createdAt   DateTime
  updatedAt   DateTime
  resolvedAt  DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleId])
  @@index([score])
}
