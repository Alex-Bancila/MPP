{
  "info": {
    "name": "Music-core REST (Assignment 2)",
    "description": "REST endpoints for Music-core bronze demonstration. GraphQL remains the primary client API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "listingId",
      "value": "listing_1"
    },
    {
      "key": "reviewId",
      "value": "review_1"
    },
    {
      "key": "userId",
      "value": "user_1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Listings",
      "item": [
        {
          "name": "GET /listings (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/listings?page=1&pageSize=6",
              "host": ["{{baseUrl}}"],
              "path": ["listings"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "6" }
              ]
            }
          }
        },
        {
          "name": "GET /listings/:listingId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/listings/{{listingId}}"
          }
        },
        {
          "name": "POST /listings",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Test Listing\",\n  \"description\": \"Created via Postman for Assignment 2 REST demonstration.\",\n  \"price\": 499,\n  \"category\": \"Accessories\",\n  \"photos\": [\"https://picsum.photos/seed/postman/1200/900\"],\n  \"sellerId\": \"user_1\"\n}"
            },
            "url": "{{baseUrl}}/listings"
          }
        },
        {
          "name": "PATCH /listings/:listingId",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Sold\",\n  \"price\": 550\n}"
            },
            "url": "{{baseUrl}}/listings/{{listingId}}"
          }
        },
        {
          "name": "DELETE /listings/:listingId",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/listings/{{listingId}}"
          }
        }
      ]
    },
    {
      "name": "Statistics",
      "item": [
        {
          "name": "GET /stats/summary",
          "request": { "method": "GET", "url": "{{baseUrl}}/stats/summary" }
        },
        {
          "name": "GET /stats/categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/stats/categories" }
        },
        {
          "name": "GET /stats/sellers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/stats/sellers?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["stats", "sellers"],
              "query": [{ "key": "limit", "value": "5" }]
            }
          }
        },
        {
          "name": "GET /stats/favourites",
          "request": { "method": "GET", "url": "{{baseUrl}}/stats/favourites" }
        },
        {
          "name": "GET /stats/reviews",
          "request": { "method": "GET", "url": "{{baseUrl}}/stats/reviews" }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "GET /listings/:listingId/reviews",
          "request": { "method": "GET", "url": "{{baseUrl}}/listings/{{listingId}}/reviews" }
        },
        {
          "name": "POST /listings/:listingId/reviews",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"userId\": \"user_2\",\n  \"rating\": 5,\n  \"title\": \"Great gear\",\n  \"body\": \"Exactly as described.\"\n}"
            },
            "url": "{{baseUrl}}/listings/{{listingId}}/reviews"
          }
        },
        {
          "name": "PATCH /reviews/:reviewId",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"body\": \"Updated via Postman.\"\n}"
            },
            "url": "{{baseUrl}}/reviews/{{reviewId}}"
          }
        },
        {
          "name": "DELETE /reviews/:reviewId",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/reviews/{{reviewId}}" }
        }
      ]
    },
    {
      "name": "Favourites",
      "item": [
        {
          "name": "GET /favourites",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/favourites?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["favourites"],
              "query": [{ "key": "userId", "value": "{{userId}}" }]
            }
          }
        },
        {
          "name": "POST /favourites",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"listingId\": \"listing_2\"\n}"
            },
            "url": "{{baseUrl}}/favourites"
          }
        },
        {
          "name": "DELETE /favourites/:listingId",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/favourites/listing_2?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["favourites", "listing_2"],
              "query": [{ "key": "userId", "value": "{{userId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex@musiccore.local\",\n  \"password\": \"RiffMaster123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_demo\",\n  \"email\": \"postman.demo@musiccore.test\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        }
      ]
    },
    {
      "name": "Generator",
      "item": [
        {
          "name": "POST /admin/generate/start",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batchSize\": 2,\n  \"intervalMs\": 2000,\n  \"entityType\": \"listings\"\n}"
            },
            "url": "{{baseUrl}}/admin/generate/start"
          }
        },
        {
          "name": "POST /admin/generate/stop",
          "request": { "method": "POST", "url": "{{baseUrl}}/admin/generate/stop" }
        }
      ]
    }
  ]
}
