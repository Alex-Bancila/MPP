# API base URL for GraphQL and REST auth (optional in dev; Vite proxies same-origin).
# VITE_API_BASE_URL=http://localhost:3001

# Dev WebSocket: default is same as the page (Vite proxies /ws). Set true to use ws://<host>:3001/ws instead.
# VITE_WS_DIRECT=true

# Optional: full WebSocket URL override.
# VITE_WS_URL=ws://192.168.1.10:5173/ws

